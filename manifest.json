{
  "manifest_version": 3,
  "name": "Lugatic",
  "version": "0.5.0",

  "author": "Emre Ihtiyaroglu",
  "homepage_url": "https://github.com/emreihtiyaroglu/lugatic",

  "description": "Lugatic — instant dictionary lookup, offline and online",

  "icons": {
    "16": "assets/icons/lugatic-16.png",
    "32": "assets/icons/lugatic-32.png",
    "48": "assets/icons/lugatic-48.png",
    "128": "assets/icons/lugatic-128.png"
  },

  "options_ui": {
    "page": "src/options/options.html"
  },

  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },

  "sidebar_action": {
    "default_title": "Lugatic",
    "default_panel": "src/sidepanel/sidepanel.html",
    "default_icon": {
      "16": "assets/icons/lugatic-16.png",
      "32": "assets/icons/lugatic-32.png"
    },
    "open_at_install": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/shared/browser-polyfill.js",
        "src/content/dictionary.js"
      ]
    }
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "scripts": [
      "src/shared/browser-polyfill.js",
      "src/shared/normalization.js",
      "src/shared/sense-ranking.js",
      "src/shared/lemmatize.js",
      "src/shared/db.js",
      "src/background/dataset-import.js",
      "src/background/background.js"
    ]
  },

  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel"
  ],

  "minimum_chrome_version": "121",
  "browser_specific_settings": {
    "gecko": {
      "id": "lugatic@emreihtiyaroglu.github.io",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
