{
  "name": "lugatic",
  "version": "0.1.0",
  "description": "Lugatic — instant dictionary lookup, offline and online (browser extension)",
  "private": true,
  "license": "GPL-3.0",
  "homepage": "https://github.com/emreihtiyaroglu/lugatic",
  "repository": {
    "type": "git",
    "url": "https://github.com/emreihtiyaroglu/lugatic.git"
  },
  "scripts": {
    "update-polyfill": "cp node_modules/webextension-polyfill/dist/browser-polyfill.js src/shared/browser-polyfill.js",
    "lint": "web-ext lint",
    "lint:js": "eslint .",
    "test": "node --test",
    "build": "web-ext build --overwrite-dest"
  },
  "webExt": {
    "sourceDir": ".",
    "ignoreFiles": [
      "node_modules/**",
      "web-ext-artifacts/**",
      "data-pipeline",
      "data-pipeline/**",
      "tests",
      "tests/**",
      "package.json",
      "package-lock.json",
      "eslint.config.mjs",
      "*.md",
      ".github/**"
    ]
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "web-ext": "^8.7.1"
  }
}
